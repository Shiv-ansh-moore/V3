<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="expo.modules.screentimelocks" >

    <uses-sdk android:minSdkVersion="24" />

    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application>
        <service
            android:name="expo.modules.screentimelocks.AppBlockerService"
            android:exported="true"
            android:label="V3 App Blocker"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:process=":blocker" >
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/blocker_config" />
        </service>

        <activity
            android:name="expo.modules.screentimelocks.WarningActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/Theme.AppCompat.NoActionBar" />
    </application>

</manifest>